{
  "name": "webapp",
  "version": "0.1.0",
  "private": true,
  "main": "electron-main.js",
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "next lint",
    "electron-dev": "electron .",
    "build:standalone": "next build && node copy-static.js",
    "pack": "electron-builder --dir",
    "dist": "electron-builder"
  },
  "dependencies": {
    "@supabase/ssr": "^0.3.0",
    "@supabase/supabase-js": "^2.49.0",
    "clsx": "^2.1.1",
    "framer-motion": "^12.4.7",
    "lucide-react": "^0.476.0",
    "next": "15.2.6",
    "react": "19.0.0",
    "react-dom": "19.0.0",
    "tailwind-merge": "^3.0.2"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4.0.0",
    "@types/node": "^22",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "electron": "^33.2.1",
    "electron-builder": "^25.1.8",
    "eslint": "^9",
    "eslint-config-next": "15.2.1",
    "postcss": "^8",
    "tailwindcss": "4.0.0",
    "typescript": "^5"
  },
  "build": {
    "appId": "com.upfeedth.app",
    "productName": "UPFEEDTH",
    "directories": {
      "output": "dist"
    },
    "files": [
      "electron-main.js",
      "launcher-gui.html",
      ".next/standalone/**/*",
      "public/**/*",
      ".next/static/**/*"
    ],
    "win": {
      "target": "nsis"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "UPFEEDTH"
    }
  }
}